{
  "name": "oth-surf-menu-bar",
  "version": "1.0.0",
  "description": "oth.surf macOS menu bar application",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "node --check src/main.js",
    "package": "npm run build && electron-builder --mac dmg --publish never"
  },
  "build": {
    "appId": "com.othsurf.menubar",
    "productName": "OTH SURF",
    "files": [
      "src/main.js",
      "src/index.html",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.weather",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "OTH SURF-v${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "menubar": "^5.2.3"
  }
}
