# oth.surf Scraper Environment Variables
# Copy this file to .env and fill in your values

# Surflin Relay API (for tide data if available)
# SURFLIN_API_KEY=your_key_here

# oth.surf website URL
OTH_SURF_URL=https://oth.surf

# Puppeteer browser args (adjust for your system)
PUPPETEER_ARGS=--no-sandbox --disable-setuid-sandbox

# Server port
PORT=3001
